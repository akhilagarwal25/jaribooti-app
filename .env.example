# Shopify Storefront API
EXPO_PUBLIC_SHOPIFY_STORE_DOMAIN=jaribooti.myshopify.com
EXPO_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token_here

# Google OAuth (optional)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# OTP Service (optional)
EXPO_PUBLIC_OTP_API_KEY=your_otp_api_key

# Firebase (for Push Notifications)
# Get these from Firebase Console -> Project Settings -> Your Apps -> SDK setup
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Expo Project ID (from expo.dev)
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id

# EAS Build
EAS_BUILD_PROFILE=preview
